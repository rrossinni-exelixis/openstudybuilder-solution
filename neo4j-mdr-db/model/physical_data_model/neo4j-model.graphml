            <node id="n165::n1::n5">
              <data key="d6">
                <y:GenericNode configuration="com.yworks.sbgn.NucleicAcidFeature">
                  <y:Geometry height="167.7647871452143" width="626.4199980371291" x="2839.122808682141" y="-2160.842861175486"/>
                  <y:Fill color="#FFFFFF" transparent="false"/>
